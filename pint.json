{
  "preset": "laravel",
  "rules": {
    "phpdoc_to_comment": false,
    "phpdoc_types": false,
    "fully_qualified_strict_types": false,
    "no_unused_imports": true,
    "no_superfluous_phpdoc_tags": true,
    "phpdoc_trim_consecutive_blank_line_separation": true,
    "phpdoc_separation": true,
    "phpdoc_summary": true,
    "phpdoc_align": false
  }
}